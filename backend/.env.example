# ============================================
# 复制本文件为 .env 并填入真实值：cp .env.example .env
# .env 含密钥，已被 .gitignore 排除，绝不入库
# ============================================

# 会话签名密钥（随便一长串随机字符，越长越好）
# 生成方法：python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# 公网地址（OAuth 回调用，必须和 Google 后台登记的一致）
# 本地测试：http://localhost:8000
# 正式部署：https://learn.yang-888.com
BASE_URL=http://localhost:8000

# 数据库（SQLite 单文件，单用户够用；以后多用户可换 PostgreSQL）
DATABASE_URL=sqlite:///./app.db

# 谷歌 OAuth 凭据（在 Google Cloud Console 创建后填入）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 白名单：只有这些邮箱能登录，逗号分隔
ALLOWED_EMAILS=yangtianwei600@gmail.com

# 会话 Cookie 是否仅限 HTTPS（确认 HTTPS 部署好后改成 true）
COOKIE_SECURE=false
