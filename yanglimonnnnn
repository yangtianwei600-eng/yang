<script>
// ═══════════════════════════════════════════
// THREE.JS WebGL 粒子爱心系统
// ═══════════════════════════════════════════
(function(){
  const canvas = document.getElementById('threeCanvas');
  const W = window.innerWidth, H = window.innerHeight;
  const DPR = Math.min(window.devicePixelRatio || 1, 2);

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: false, alpha: true });
  renderer.setPixelRatio(DPR);
  renderer.setSize(W, H);
  renderer.setClearColor(0x060610, 1);

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(60, W / H, 0.1, 1000);
  camera.position.z = 5;

  // ── 爱心坐标（初始化一次）──
  const COUNT = 1200;
  const positions = new Float32Array(COUNT * 3);
  const origins   = new Float32Array(COUNT * 3);
  const randoms   = new Float32Array(COUNT * 3);

  const scale = 1.4;
  for(let i = 0; i < COUNT; i++){
    const t = (i / COUNT) * Math.PI * 2;
    const x = 16 * Math.pow(Math.sin(t), 3);
    const y = 13 * Math.cos(t) - 5 * Math.cos(2*t) - 2 * Math.cos(3*t) - Math.cos(4*t);
    const hx = (x / 16) * scale;
    const hy = (y / 16) * scale;
    origins[i*3]   = hx;
    origins[i*3+1] = hy;
    origins[i*3+2] = 0;
    // 初始位置随机散开
    positions[i*3]   = (Math.random() - 0.5) * 10;
    positions[i*3+1] = (Math.random() - 0.5) * 10;
    positions[i*3+2] = (Math.random() - 0.5) * 2;
    randoms[i*3]   = Math.random();
    randoms[i*3+1] = Math.random() * Math.PI * 2;
    randoms[i*3+2] = Math.random() * 0.5 + 0.5;
  }

  const geo = new THREE.BufferGeometry();
  geo.setAttribute('position', new THREE.BufferAttribute(positions, 3));
  geo.setAttribute('aOrigin',  new THREE.BufferAttribute(origins, 3));
  geo.setAttribute('aRandom',  new THREE.BufferAttribute(randoms, 3));

  // ── ShaderMaterial ──
  const mat = new THREE.ShaderMaterial({
    uniforms: {
      uTime:    { value: 0 },
      uPointer: { value: new THREE.Vector2(9999, 9999) },
      uProgress:{ value: 0 }
    },
    vertexShader: \`
      uniform float uTime;
      uniform vec2  uPointer;
      uniform float uProgress;
      attribute vec3 aOrigin;
      attribute vec3 aRandom;
      varying float vAlpha;
      varying vec3  vColor;

      void main(){
        // 吸附到爱心
        float prog = clamp(uProgress, 0.0, 1.0);
        float ease = 1.0 - pow(1.0 - prog, 3.0);

        vec3 pos = mix(position, aOrigin, ease);

        // 持续流动：sin/cos 波动
        float flow = aRandom.y + uTime * (0.4 + aRandom.z * 0.4);
        pos.x += sin(flow) * 0.045 * (1.0 - ease * 0.3);
        pos.y += cos(flow * 1.3) * 0.035 * (1.0 - ease * 0.3);

        // 呼吸
        float breath = 1.0 + sin(uTime * 0.9 + aRandom.y * 6.28) * 0.025;
        pos.xy *= breath;

        // 手指力场
        vec4 worldPos = modelMatrix * vec4(pos, 1.0);
        vec2 diff = worldPos.xy - uPointer;
        float dist = length(diff);
        float force = 0.35 / (dist * dist + 0.3);
        pos.xy += normalize(diff) * force * 0.18;

        vAlpha = 0.5 + 0.5 * sin(uTime * 1.5 + aRandom.y * 6.28);
        vAlpha *= (0.7 + aRandom.z * 0.3);

        // 颜色：蓝→紫→粉
        float hue = fract(aRandom.x + uTime * 0.04);
        if(hue < 0.33){
          vColor = mix(vec3(0.49,0.83,1.0), vec3(0.655,0.545,0.98), hue * 3.0);
        } else if(hue < 0.66){
          vColor = mix(vec3(0.655,0.545,0.98), vec3(0.957,0.447,0.714), (hue-0.33)*3.0);
        } else {
          vColor = mix(vec3(0.957,0.447,0.714), vec3(0.49,0.83,1.0), (hue-0.66)*3.0);
        }

        gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
        gl_PointSize = (2.5 + aRandom.z * 2.0) * (1.0 / -gl_Position.z + 1.5);
      }
    \`,
    fragmentShader: \`
      varying float vAlpha;
      varying vec3  vColor;
      void main(){
        vec2 uv = gl_PointCoord - 0.5;
        float d = length(uv);
        if(d > 0.5) discard;
        float glow = 1.0 - smoothstep(0.0, 0.5, d);
        glow = pow(glow, 1.4);
        gl_FragColor = vec4(vColor, glow * vAlpha);
      }
    \`,
    transparent: true,
    blending: THREE.AdditiveBlending,
    depthWrite: false
  });

  const points = new THREE.Points(geo, mat);
  scene.add(points);

  // ── 吸附进度动画 ──
  let progress = 0;
  const pointer = new THREE.Vector2(9999, 9999);

  // ── 手指/鼠标 ──
  function updatePointer(clientX, clientY){
    const x = (clientX / window.innerWidth)  * 2 - 1;
    const y = -(clientY / window.innerHeight) * 2 + 1;
    // 转换到世界坐标（z=0平面）
    pointer.set(x * camera.aspect * Math.tan(THREE.MathUtils.degToRad(30)) * camera.position.z,
                y * Math.tan(THREE.MathUtils.degToRad(30)) * camera.position.z);
  }
  window.addEventListener('mousemove', e => updatePointer(e.clientX, e.clientY));
  window.addEventListener('touchmove', e => {
    e.preventDefault();
    updatePointer(e.touches[0].clientX, e.touches[0].clientY);
  }, { passive: false });
  window.addEventListener('mouseleave', () => pointer.set(9999, 9999));
  window.addEventListener('touchend',   () => pointer.set(9999, 9999));

  // ── resize ──
  window.addEventListener('resize', () => {
    const w = window.innerWidth, h = window.innerHeight;
    renderer.setSize(w, h);
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
  });

  // ── 动画循环 ──
  let t = 0;
  function animate(){
    requestAnimationFrame(animate);
    t += 0.016;
    progress = Math.min(1, progress + 0.006);
    mat.uniforms.uTime.value    = t;
    mat.uniforms.uProgress.value = progress;
    mat.uniforms.uPointer.value.set(pointer.x, pointer.y);
    renderer.render(scene, camera);
  }
  animate();
})();

