// 上传弹窗
// ═══════════════════════════════════════════
function openModal(){ document.getElementById('modal').classList.add('open'); }
function closeModal(){
  document.getElementById('modal').classList.remove('open');
  document.getElementById('fileInput').value='';
  document.getElementById('dropLabel').textContent='Click to choose a photo';
  document.getElementById('uploadMsg').textContent='';
}
function previewFile(input){
  if(input.files[0]) document.getElementById('dropLabel').textContent='📷 '+input.files[0].name;
}
async function doUpload(){
  const f=document.getElementById('fileInput').files[0];
  const msg=document.getElementById('uploadMsg');
  if(!f){msg.textContent='Please choose a photo first.';return;}
  msg.textContent='Uploading...';
  const fd=new FormData();fd.append('photo',f);
  const r=await fetch('/upload',{method:'POST',body:fd});
  const data=await r.json();
  if(data.success){closeModal();location.reload();}
  else{msg.textContent=data.message||'Upload failed.';}
}
document.getElementById('modal').addEventListener('click',function(e){
  if(e.target===this)closeModal();
});
